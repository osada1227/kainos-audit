# Streamlit Cloud → App settings → Secrets に貼り付ける雛形.
# ローカル動作確認は .streamlit/secrets.toml にコピーして値を埋める。
# (.streamlit/secrets.toml 自体は .gitignore 済み)

[auth]
# 認証クッキー署名キー。setup_initial.py が生成した値を貼り付ける。
cookie_key = "REPLACE_WITH_setup_initial.py_OUTPUT"

[anthropic]
# サーバー側共通 API キー。これを設定するとカイノス様は自分でキーを入力する必要なし。
# console.anthropic.com で発行した sk-ant- で始まる文字列。
api_key = "sk-ant-REPLACE_WITH_YOUR_KEY"
